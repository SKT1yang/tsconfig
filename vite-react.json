{
  "$schema": "https://www.schemastore.org/tsconfig",
  "display": "Vite React App",
  "extends": ["./base.json", "./strictest.json"],
  "compilerOptions": {
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "allowImportingTsExtensions": true,
    "types": ["vite/client"],
    "noEmit": true,
    "jsx": "react-jsx"
  }
}

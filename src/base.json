{
  "$schema": "https://www.schemastore.org/tsconfig",
  "display": "Base",
  "compilerOptions": {
    "module": "esnext",
    "target": "es2024",
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "erasableSyntaxOnly": true,
    "isolatedModules": true
  }
}

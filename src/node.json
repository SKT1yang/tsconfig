{
  "$schema": "https://www.schemastore.org/tsconfig",
  "display": "Node",
  "extends": [
    "./base.json",
    "./strictest.json"
  ],
  "compilerOptions": {
    "lib": [
      "ES2024",
      "ESNext.Array",
      "ESNext.Collection",
      "ESNext.Iterator",
      "ESNext.Promise"
    ],
    "moduleResolution": "bundler",
    "rewriteRelativeImportExtensions": true
  }
}
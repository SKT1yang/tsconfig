{
  "compilerOptions": {
    "target": "ES2025", 
    "lib": ["ES2025"], 

    
    "module": "nodenext",
    
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true, 

    
    "outDir": "./dist",
    "rootDir": "./src",
    "sourceMap": true, 

    
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,

    
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true 
  }
}